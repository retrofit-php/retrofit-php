{
    "name": "retrofit-php/retrofit-php",
    "description": "Retrofit for PHP - A type-safe PHP REST client",
    "type": "library",
    "keywords": [
        "http",
        "http-client",
        "rest",
        "rest-client",
        "retrofit"
    ],
    "homepage": "https://github.com/retrofit-php/retrofit-php",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/retrofit-php/retrofit-php/issues"
    },
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.4.1",
        "guzzlehttp/guzzle": "~7.10.0",
        "guzzlehttp/psr7": "~2.9.0 || ~2.10.0",
        "letsdrink/ouzo-goodies": "dev-master",
        "nikic/php-parser": "~5.7.0",
        "phpdocumentor/reflection-docblock": "~6.0.3",
        "psr/http-message": "~2.0",
        "rawr/t-regx": "~0.41.5",
        "symfony/serializer": "~7.4.8"
    },
    "require-dev": {
        "phpunit/phpunit": "~13.1.7",
        "symfony/property-access": "~7.4.8"
    },
    "autoload": {
        "psr-4": {
            "Retrofit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Retrofit\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
