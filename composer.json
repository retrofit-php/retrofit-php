{
    "name": "thulium/retrofit-php",
    "description": "Retrofit for PHP - A type-safe PHP REST client",
    "type": "library",
    "keywords": [
        "http",
        "http-client",
        "rest",
        "rest-client",
        "retrofit"
    ],
    "homepage": "https://github.com/thulium/retrofit-php",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/thulium/retrofit-php/issues"
    },
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.4",
        "guzzlehttp/guzzle": "^7.7",
        "guzzlehttp/psr7": "^2.5",
        "letsdrink/ouzo-goodies": "dev-master",
        "nikic/php-parser": "^5.7",
        "phpdocumentor/reflection-docblock": "^6.0",
        "psr/http-message": "^2.0",
        "rawr/t-regx": "^0.41",
        "symfony/serializer": "~7.4.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "symfony/property-access": "~7.4.8"
    },
    "autoload": {
        "psr-4": {
            "Retrofit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Retrofit\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
